# Frontend runtime
VITE_API_BASE_URL=
VITE_ADMIN_API_TOKEN=
VITE_VERIFIER_API_TOKEN=
VITE_FUZZY_MATCH_THRESHOLD=0.75
VITE_SEARCH_RADIUS_METERS=50

# Backend API server
API_SERVER_PORT=8787

# Phase 6: production persistence
ENABLE_SUPABASE_PERSISTENCE=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 5: security hardening
ADMIN_API_TOKEN=
VERIFIER_API_TOKENS=
ENFORCE_ADMIN_AUTH=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
AUDIT_LOG_FILE=server/logs/audit.log

# Secure provider keys (keep only on server)
GEMINI_API_KEY=
GEMINI_BACKUP_KEYS=

GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_BACKUP_KEYS=
MAPS_PROXY_URLS=

# Optional client-side fallback keys (not recommended for production)
VITE_GEMINI_API_KEY=
VITE_GEMINI_BACKUP_KEYS=
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_BACKUP_KEYS=
VITE_MAPS_PROXY_URLS=

# Supabase (currently used by client persistence sync)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Google Cloud ──────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=asia-southeast2
