{
  "name": "invisible-map",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "tsx server/index.ts",
    "start": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "pwa:dev": "npm run dev:web",
    "pipeline:seed": "tsx scripts/seed.ts",
    "pipeline:benchmark": "tsx scripts/benchmark.ts",
    "db:migrate": "echo 'Run migrations in supabase/migrations/ via Supabase SQL Editor or CLI'",
    "worker:validate": "tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jimp": "^1.6.1",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.5"
  }
}
